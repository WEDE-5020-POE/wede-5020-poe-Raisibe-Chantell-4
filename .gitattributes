# Auto det# Ensure consistent line endings (LF for all text files)
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Treat HTML as text for diffs (default, but explicit here)
*.html diff

# Mark images and other binary files
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.svg  text

# Prevent merge conflicts in minified files (treat as binary)
*.min.js binary
*.min.css binary

# Optional: enforce UTF-8 encoding for HTML
*.html =UTF-8
